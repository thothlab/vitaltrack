# --- Telegram ---
BOT_TOKEN=000000:replace-me
WEBHOOK_BASE_URL=https://example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=change-me-to-a-random-string

# --- Bootstrap doctor IDs (comma-separated Telegram user ids) ---
DOCTOR_BOOTSTRAP_IDS=

# --- App ---
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=vitaltrack
POSTGRES_USER=vitaltrack
POSTGRES_PASSWORD=change-me

# --- Redis (used by aiogram FSM storage) ---
REDIS_URL=redis://redis:6379/0

# --- Alerts (defaults; per-user overrides in DB) ---
ALERT_BP_SYS_HIGH=160
ALERT_BP_DIA_HIGH=100
ALERT_BP_SYS_LOW=90
ALERT_BP_DIA_LOW=60
ALERT_GLUCOSE_LOW=3.9
ALERT_GLUCOSE_HIGH=11.1
ALERT_NO_DATA_DAYS=3
ALERT_MISSED_MED_HOURS=2
